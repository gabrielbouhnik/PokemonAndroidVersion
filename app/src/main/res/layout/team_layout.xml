<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
                                                   xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:tools="http://schemas.android.com/tools" android:layout_width="match_parent"
                                                   android:layout_height="match_parent"
                                                   android:background="@drawable/pokemon_background">

    <androidx.recyclerview.widget.RecyclerView
            android:layout_width="200dp"
            android:layout_height="600dp"
            android:id="@+id/teamRecyclerView"
            app:layout_constraintEnd_toEndOf="parent" app:layout_constraintBottom_toTopOf="@+id/teamMenuBackButton"/>
    <androidx.recyclerview.widget.RecyclerView
            android:layout_width="200dp"
            android:layout_height="600dp"
            android:id="@+id/pokemonsRecyclerView"
            app:layout_constraintStart_toStartOf="parent" app:layout_constraintBottom_toTopOf="@+id/teamMenuBackButton">
    </androidx.recyclerview.widget.RecyclerView>
    <Button
            android:text="Back"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:id="@+id/teamMenuBackButton"
            app:layout_constraintEnd_toEndOf="parent" app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_marginBottom="32dp"/>
</androidx.constraintlayout.widget.ConstraintLayout>