<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
                                                   xmlns:tools="http://schemas.android.com/tools"
                                                   xmlns:app="http://schemas.android.com/apk/res-auto"
                                                   android:layout_width="match_parent"
                                                   android:layout_height="match_parent">
    <androidx.recyclerview.widget.RecyclerView
            android:layout_width="190dp"
            android:layout_height="460dp"
            android:id="@+id/pokemonsBattleTowerRecyclerView"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintBottom_toTopOf="@+id/validateTeamSelectionButton" android:layout_marginStart="4dp"
            android:layout_marginBottom="72dp" app:layout_constraintTop_toTopOf="parent"
    />
    <androidx.recyclerview.widget.RecyclerView
            android:layout_width="190dp"
            android:layout_height="460dp"
            android:id="@+id/teamBattleTowerRecyclerView"
            app:layout_constraintEnd_toEndOf="parent" android:layout_marginBottom="72dp"
            app:layout_constraintBottom_toTopOf="@+id/validateTeamSelectionButton"
            android:layout_marginEnd="4dp"
            app:layout_constraintTop_toTopOf="parent">
    </androidx.recyclerview.widget.RecyclerView>
    <Button
            android:text="Back"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:id="@+id/battleTowerBackButton"
            app:layout_constraintEnd_toEndOf="parent" app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" android:layout_marginBottom="32dp"/>
    <Button
            android:text="Validate Selection"
            android:layout_width="290dp"
            android:layout_height="66dp" android:id="@+id/validateTeamSelectionButton"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:backgroundTint="#673AB7"
            app:layout_constraintBottom_toTopOf="@+id/battleTowerBackButton" android:layout_marginBottom="32dp"/>
</androidx.constraintlayout.widget.ConstraintLayout>